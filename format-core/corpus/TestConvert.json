[
  {
    "name": "tabular uniform array source-order columns",
    "input": "[{\"id\":1,\"name\":\"Ada\"},{\"id\":2,\"name\":\"Lin\"}]",
    "opts": {
      "format": "toon",
      "indent": 2,
      "delimiter": ",",
      "strict": null
    },
    "expected_format": null,
    "expected_output": "[2]{id,name}:\n  1,Ada\n  2,Lin",
    "expect_error": false,
    "expect_passthrough": false
  },
  {
    "name": "key order preserved with non-alphabetical keys",
    "input": "{\"zeta\":1,\"alpha\":2}",
    "opts": {
      "format": "toon",
      "indent": 2,
      "delimiter": ",",
      "strict": null
    },
    "expected_format": null,
    "expected_output": "zeta: 1\nalpha: 2",
    "expect_error": false,
    "expect_passthrough": false
  },
  {
