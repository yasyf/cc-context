{
  "id": "mux-diff-multifile",
  "category": "diff_review",
  "repo": "gorilla-mux",
  "prompt": "The working tree has uncommitted changes, possibly across multiple files. Which top-level functions or methods were modified relative to HEAD? List their names.",
  "schema": {
    "type": "object",
    "properties": {
      "symbols": {
        "type": "array",
        "items": {
          "type": "string"
        }
      }
    },
    "required": [
      "symbols"
    ],
    "additionalProperties": false
  },
  "grader": {
    "kind": "set_match",
    "spec": {
      "field": "symbols",
      "mode": "equal",
      "lower": true
    }
  },
  "gold": {
    "symbols": [
      "NewRouter",
      "GetName"
    ]
  },
  "ccx_helps": true,
  "setup": {
    "edits": [
      {
        "file": "mux.go",
        "find": "return &Router{namedRoutes: make(map[string]*Route)}",
        "replace": "return &Router{namedRoutes: make(map[string]*Route)} //nolint"
      },
      {
        "file": "route.go",
        "find": "return r.name",
        "replace": "return r.name //nolint"
      }
    ]
  }
}