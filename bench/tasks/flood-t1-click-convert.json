{
  "id": "flood-t1-click-convert",
  "category": "large_context",
  "repo": "click",
  "prompt": "In `src/click/types.py`, enumerate every module-scope public class whose own body defines a method named `convert`, declared directly and not inherited. List each class name exactly once.",
  "schema": {
    "type": "object",
    "properties": {
      "members": {
        "type": "array",
        "items": {
          "type": "string"
        }
      }
    },
    "required": [
      "members"
    ],
    "additionalProperties": false
  },
  "grader": {
    "kind": "set_match",
    "spec": {
      "field": "members",
      "mode": "equal",
      "lower": true
    }
  },
  "gold": {
    "lc_predicate": {
      "kind": "py_method",
      "file": "src/click/types.py",
      "target": "convert",
      "expect_members": 11
    },
    "traversal_files": [
      "src/click/types.py"
    ],
    "members": [
      "BoolParamType",
      "Choice",
      "DateTime",
      "File",
      "FuncParamType",
      "ParamType",
      "Path",
      "StringParamType",
      "Tuple",
      "UUIDParameterType",
      "UnprocessedParamType"
    ]
  },
  "ccx_helps": true,
  "setup": {},
  "floor_exempt": true,
  "arm_addenda": {}
}