#!/bin/sh
# cc-context bootstrap shim: resolve a cached `ccx` binary, downloading the
# pinned release on first run, then exec it with the original arguments.
#
# NOTE: the GitHub release download 404s until a `v*` release is cut. Until
# then the dev fallback below (a co-located built binary or a `ccx` on PATH)
# is what runs.
set -eu

CCX_VERSION="v0.1.0"

cache_dir="${CLAUDE_PLUGIN_DATA:-${XDG_CACHE_HOME:-$HOME/.cache}/cc-context}/bin"
cached="$cache_dir/ccx-$CCX_VERSION"

# Cached pinned binary wins.
if [ -x "$cached" ]; then
	exec "$cached" "$@"
fi

# Dev fallback: a co-located built binary (repo checkout) or a `ccx` on PATH.
if [ -n "${CLAUDE_PLUGIN_ROOT:-}" ] && [ -x "$CLAUDE_PLUGIN_ROOT/../bin/ccx" ]; then
	exec "$CLAUDE_PLUGIN_ROOT/../bin/ccx" "$@"
fi
if dev_ccx="$(command -v ccx 2>/dev/null)"; then
	exec "$dev_ccx" "$@"
fi

# Detect platform and map to the goreleaser asset name.
os="$(uname -s)"
arch="$(uname -m)"

case "$os" in
	Darwin) asset_os="Darwin" ;;
	Linux) asset_os="Linux" ;;
	*)
		echo "cc-context: unsupported OS: $os" >&2
		exit 1
		;;
esac

case "$arch" in
	arm64 | aarch64) asset_arch="arm64" ;;
	x86_64 | amd64) asset_arch="x86_64" ;;
	*)
		echo "cc-context: unsupported architecture: $arch" >&2
		exit 1
		;;
esac

asset="ccx_${asset_os}_${asset_arch}.tar.gz"
url="https://github.com/yasyf/cc-context/releases/download/${CCX_VERSION}/${asset}"

mkdir -p "$cache_dir"
tmp="$(mktemp -d)"
trap 'rm -rf "$tmp"' EXIT

if command -v curl >/dev/null 2>&1; then
	curl -fsSL "$url" -o "$tmp/ccx.tar.gz"
elif command -v wget >/dev/null 2>&1; then
	wget -qO "$tmp/ccx.tar.gz" "$url"
else
	echo "cc-context: need curl or wget to download $url" >&2
	exit 1
fi

tar -xzf "$tmp/ccx.tar.gz" -C "$tmp"
chmod +x "$tmp/ccx"
mv "$tmp/ccx" "$cached"

exec "$cached" "$@"
