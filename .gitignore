# GENERATED by cc-guides from .claude/fragments/.gitignore/ — do not edit; edit the fragments and push — CI renders.
# OS / editor
.DS_Store
*.swp
.idea/
.vscode/

# Local environment
.env*

# Claude Code
.context/
.claude-scratch/
.scratch/
.claude/worktrees/
.claude/settings.local.json

# Python bytecode (guard hooks are Python even in non-Python repos)
__pycache__/
*.py[cod]

# Cargo build output — any target dir variant, anywhere (Rust cores appear in
# repos of every stack; a stray CARGO_TARGET_DIR must never reach the index)
target/
target-cargo/
.cargo-target/

# Go build output
/bin/
/dist/

# Test / coverage
*.test
*.out
coverage.txt

# go-task cache
.task/

# bootstrap verify binary smoke test
.go-smoke/

# WASM format engine, built from format-core/wasm by `task wasm` (go:embed'd)
/internal/format/formatcore.wasm

# WASM embedding engine, built from embed-core/wasm by `task wasm-embed` (go:embed'd)
/internal/semsearch/embed/embedcore.wasm

# plugin/bin is on the Bash tool's PATH; it holds only symlinks the installer
# manages (brew binary, data-dir payload, or dev build) — never a real binary
plugin/bin/*
!plugin/bin/.gitkeep

# agent scratchpads and stray root builds
/ccx
