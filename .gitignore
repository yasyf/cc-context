# OS / editor
.DS_Store
*.swp
.idea/
.vscode/

# Local environment
.env*

# Claude Code
.context/
.claude/settings.local.json

# Python bytecode (guard hooks are Python even in non-Python repos)
__pycache__/
*.py[cod]

# Go build output
/bin/
/dist/

# WASM format engine, built from format-core/wasm by `task wasm` (go:embed'd)
/internal/format/formatcore.wasm

# Test / coverage
*.test
*.out
coverage.txt

# go-task cache
.task/

# bootstrap verify binary smoke test
.go-smoke/

# plugin/bin is on the Bash tool's PATH; it holds only symlinks the installer
# manages (brew binary, data-dir payload, or dev build) — never a real binary
plugin/bin/*
!plugin/bin/.gitkeep

# agent scratchpads and stray root builds
.scratch/
.claude-scratch/
/ccx
